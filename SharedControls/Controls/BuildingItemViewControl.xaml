<UserControl x:Class="Shared.Controls.BuildingItemViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Shared.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <StackPanel x:Name="spResult" Orientation="Horizontal" HorizontalAlignment="Stretch"
                    Margin="5" Background="Fuchsia" AllowDrop="True" Drop="spDropZone_Drop">
            <Button Content="Placeholder"/>
            <!-- Dropped words will be arranged here -->
        </StackPanel>

        <StackPanel x:Name="spShuffledWords" Margin="15" AllowDrop="True" Orientation="Horizontal">
            <!-- Words will be placed here at different angles -->
        </StackPanel>
    </StackPanel>
</UserControl>
